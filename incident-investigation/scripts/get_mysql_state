#!/usr/bin/env python3

import sys
import json
from datetime import datetime


def get_mock_mysql_state(host="10.21.4.15", port=3306):
    """获取 MySQL 状态（mock 数据）"""
    now = datetime.now().isoformat()
    return {
        "host": host,
        "port": port,
        "timestamp": now,
        "status": "unreachable",  # 模拟不可达状态
        "connection_attempts": [
            {"timestamp": now, "result": "timeout", "duration": "5.0s"},
            {"timestamp": now, "result": "timeout", "duration": "5.0s"},
            {"timestamp": now, "result": "timeout", "duration": "5.0s"}
        ],
        "metrics": {
            "threads_connected": 0,
            "threads_running": 0,
            "connections": 0,
            "max_connections": 200,
            "cpu_usage": "N/A",
            "memory_usage": "N/A"
        },
        "error": "dial tcp {}:{}: i/o timeout".format(host, port),
        "suggestions": [
            "检查网络连通性",
            "检查防火墙/安全组规则",
            "检查 MySQL 实例是否存活",
            "检查 MySQL 是否有连接数限制"
        ]
    }


def main():
    host = "10.21.4.15"
    port = 3306

    if len(sys.argv) >= 2:
        host = sys.argv[1]
    if len(sys.argv) >= 3:
        port = int(sys.argv[2])

    state = get_mock_mysql_state(host, port)
    print(json.dumps(state, indent=2, ensure_ascii=False))


if __name__ == "__main__":
    main()
